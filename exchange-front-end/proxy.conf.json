{
  "/api/*": {
    "target": "http://localhost:8090",
    "secure": false,
    "logLevel": "debug",
    "pathRewrite": {
      "^/api": ""
    },
    "changeOrigin": true
  },
  "/socket/*": {
    "target": "ws://localhost:8090",
    "secure": false,
    "ws": true,
    "pathRewrite": {
      "^/socket": ""
    }
  }
}
